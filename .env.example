# ─── Database (Supabase) ────────────────────────────────────────────────────
# Use the "Transaction" pooler URL from Supabase → Settings → Database → Connection string
# Port 6543 is the PgBouncer pooler (recommended for serverless/Vercel)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── Auth ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# ─── Admin credentials ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# ─── CORS (API server) ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Leave empty to allow all origins (development default).
# Example: https://fiirso.vercel.app,https://fiirso-admin.vercel.app
ALLOWED_ORIGINS=

# ─── TMDB (optional – required for import feature) ──────────────────────────
TMDB_API_KEY=your-tmdb-api-key

# ─── Frontend env vars (set in Vercel dashboard per project) ─────────────────
# Full URL of your deployed API server — used by the frontends to reach the API.
# Leave empty on Replit (API is proxied through the same domain).
VITE_API_URL=https://fiirso-api.vercel.app
